# Site
NEXT_PUBLIC_SITE_NAME=川
CHUAN_PUBLIC_HOST=:80

# Runtime
NODE_ENV=production
MARKET_DATA_PROVIDER=coinglass
PERSISTENCE_SCOPE=chuan-prod
SCAN_API_RATE_LIMIT=120
JOURNAL_API_RATE_LIMIT=60
RADAR_API_RATE_LIMIT=120
RADAR_CONTRACT_API_RATE_LIMIT=120
RADAR_DOSSIER_API_RATE_LIMIT=180
CRON_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Optional private access mode. Leave disabled during open preview.
CHUAN_PRIVATE_MODE_ENABLED=false
CHUAN_SESSION_COOKIE_NAME=chuan_session
CHUAN_SESSION_PASSWORD=CHANGE_ME_PRIVATE_LOGIN_PASSWORD
CHUAN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SESSION_SECRET
CHUAN_SESSION_TTL_SECONDS=604800
AUTH_SESSION_RATE_LIMIT=30
FRONTEND_LIVE_EVENTS_RATE_LIMIT=180
FRONTEND_UI_STATE_RATE_LIMIT=180
FRONTEND_UI_STATE_MAX_BYTES=32768
FRONTEND_BACKEND_CONTRACT_CACHE_TTL_MS=5000
FRONTEND_PUBLIC_MARKET_CACHE_TTL_MS=15000

# Local PostgreSQL for single-server deployment
POSTGRES_DB=chuan_market_radar
POSTGRES_USER=chuan_radar
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_DRIVER=postgres
DATABASE_URL=postgresql://chuan_radar:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/chuan_market_radar

# Local Redis for cache/lock/queue expansion
REDIS_URL=redis://redis:6379

# CoinGlass
COINGLASS_API_KEY=CHANGE_ME_COINGLASS_API_KEY
COINGLASS_BASE_ASSETS=BTC,ETH,SOL,ENA,SUI,ONDO,TIA
COINGLASS_BATCH_SIZE=24
COINGLASS_DAILY_REQUEST_BUDGET=3000
COINGLASS_MAX_CONCURRENCY=6
COINGLASS_MINUTE_REQUEST_LIMIT=30
COINGLASS_REQUEST_INTERVAL_MS=3000
SCAN_LOCK_TTL_SECONDS=600
COINGLASS_DAILY_MOVER_MAX_ASSETS=30
COINGLASS_DAILY_MOVER_LIMIT_PER_SIDE=10
WS_LIGHT_SCAN_WINDOW_MS=900000
WS_LIGHT_SCAN_ZSCORE_THRESHOLD=2
WS_LIGHT_SCAN_MIN_CANDIDATE_VOLUME_USD=250000
WS_LIGHT_SCAN_ENABLED=true
WS_LIGHT_SCAN_WORKER_ENABLED=true
WS_LIGHT_SCAN_EXCHANGES=BINANCE,OKX,BYBIT
WS_LIGHT_SCAN_BOOK_STREAMS_ENABLED=true
WS_LIGHT_SCAN_LARGE_TAKER_TRADE_USD=100000
WS_LIGHT_SCAN_TRADE_STREAMS_ENABLED=true
WS_LIGHT_SCAN_REDIS_KEY=chuan:ws-light-scan:snapshot
WS_LIGHT_SCAN_STALE_AFTER_MS=180000
WS_LIGHT_SCAN_SNAPSHOT_INTERVAL_SECONDS=15
WS_LIGHT_SCAN_SNAPSHOT_TTL_SECONDS=1200
WS_LIGHT_SCAN_SYMBOL_LIMIT_PER_EXCHANGE=500
WS_LIGHT_SCAN_SUBSCRIBE_CHUNK_SIZE=40
WS_LIGHT_SCAN_MAX_PRIORITY_CANDIDATES=48
WS_LIGHT_SCAN_RECONNECT_SECONDS=10

# Worker cadence
WORKER_HEARTBEAT_TTL_SECONDS=1800
WORKER_HEARTBEAT_STALE_SECONDS=900
WORKER_IDLE_HEARTBEAT_SECONDS=300
SCANNER_INTERVAL_SECONDS=900
DAILY_MOVER_INTERVAL_SECONDS=86400
KLINE_CACHE_INTERVAL_SECONDS=21600
OUTCOME_INTERVAL_SECONDS=3600
V3_FORWARD_MAP_INTERVAL_SECONDS=21600
HEALTH_WATCH_INTERVAL_SECONDS=300
MACRO_INGEST_INTERVAL_SECONDS=3600

# Review and calibration budgets
KLINE_BACKTEST_DAILY_REQUEST_BUDGET=12
KLINE_BACKTEST_MAX_SYMBOLS_PER_RUN=2
OUTCOME_EXECUTOR_EVENT_LIMIT=80
V3_FORWARD_MAP_REVIEW_LIMIT=80
STRATEGY_WEIGHT_ACTIVATION_MODE=disabled

# External AI review is intentionally removed.
# Do not add AI_API_KEY here. Counter-evidence review runs through deterministic code rules.

# Legacy/rollback adapters. Keep empty unless intentionally using them again.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Candidate Episode runtime must be deployed dormant first. Production activation requires a separate
# code authorization release and database control transition; environment values alone cannot enable it.
CANDIDATE_EPISODE_CANONICAL_WRITE=false
CANDIDATE_EPISODE_SHADOW_WRITE=false
CANDIDATE_EPISODE_DUAL_READ=false
CANDIDATE_EPISODE_CANONICAL_READ=false
CANDIDATE_EPISODE_REVIEW_READ=false
CANDIDATE_RUNTIME_RELEASE_ID=disabled
CANDIDATE_SHADOW_WORKER_EXPECTED=false
CANDIDATE_SHADOW_BATCH_LIMIT=50
CANDIDATE_SHADOW_INTERVAL_SECONDS=30
CANDIDATE_SOURCE_DATABASE_URL=
CANDIDATE_CONSUMER_DATABASE_URL=
CANDIDATE_MONITOR_DATABASE_URL=
