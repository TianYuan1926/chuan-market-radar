{$CHUAN_PUBLIC_HOST} {
	encode zstd gzip

	header {
		-Server
		Content-Security-Policy "base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		Strict-Transport-Security "max-age={$CHUAN_HSTS_MAX_AGE:0}"
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}

	reverse_proxy web:3000 {
		lb_try_duration 10s
		lb_try_interval 250ms
		# Docker Compose already health-checks the only web upstream.
		# Caddy active checks can mark the whole site down during transient Docker DNS hiccups.
	}
}
