{$CHUAN_PUBLIC_HOST} {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
  }

  reverse_proxy web:3000 {
    lb_try_duration 10s
    lb_try_interval 250ms
    # Docker Compose already health-checks the only web upstream.
    # Caddy active checks can mark the whole site down during transient Docker DNS hiccups.
  }
}
