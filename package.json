{
  "name": "chuan-market-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "compose:config": "docker compose --env-file .env.production config",
    "compose:up": "docker compose --env-file .env.production up -d --build",
    "compose:down": "docker compose --env-file .env.production down",
    "deployment:env-plan": "tsc -p tsconfig.market-test.json && node .tmp/market-tests/scripts/vercel-env-plan.js",
    "start": "next start",
    "smoke:server": "bash deploy/scripts/smoke-test.sh",
    "worker:protected-api": "node deploy/workers/protected-api-worker.mjs",
    "worker:ws-light-scan": "node deploy/workers/ws-light-scan-worker.mjs",
    "lint": "eslint .",
    "test:market": "tsc -p tsconfig.market-test.json && find .tmp/market-tests/lib -name '*.test.js' -print | sort | xargs node --test && npm run test:workers",
    "test:workers": "node --test deploy/workers/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "latest",
    "next": "latest",
    "pg": "8.16.3",
    "postcss": "^8.5.15",
    "react": "latest",
    "react-dom": "latest",
    "redis": "6.0.0",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "8.15.6",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "typescript": "latest"
  },
  "browserslist": "> 1%"
}
