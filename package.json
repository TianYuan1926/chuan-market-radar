{
  "name": "chuan-market-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "compose:config": "docker compose --env-file .env.production config",
    "compose:up": "docker compose --env-file .env.production up -d --build",
    "compose:down": "docker compose --env-file .env.production down",
    "production:git-sync": "bash deploy/scripts/verify-git-sync.sh",
    "production:preflight": "bash deploy/scripts/production-preflight.sh",
    "production:ssh-check": "bash deploy/scripts/check-prod-ssh.sh",
    "production:deploy": "bash deploy/scripts/tencent-prod-deploy.sh",
    "production:drill": "bash deploy/scripts/production-drill.sh",
    "production:audit": "bash deploy/scripts/dependency-audit.sh",
    "production:logs": "bash deploy/scripts/collect-prod-logs.sh",
    "production:rollback": "bash deploy/scripts/production-rollback.sh",
    "production:smoke": "bash deploy/scripts/prod-smoke.sh",
    "backtest:audit": "node tools/radar-backtest-audit.mjs",
    "backtest:historical": "node tools/radar-historical-backtest.mjs",
    "build:market-cli": "tsc -p tsconfig.market-test.json",
    "backtest:professional": "node tools/run-professional-backtest.mjs",
    "backtest:professional-round": "node tools/run-professional-backtest.mjs -- --audit-round --days 30 --audit-symbols 10 --candidate-symbols 80 --nodes-per-symbol 10 --top-n 10",
    "deployment:env-plan": "tsc -p tsconfig.market-test.json && node .tmp/market-tests/scripts/vercel-env-plan.js",
    "start": "next start",
    "smoke:server": "bash deploy/scripts/smoke-test.sh",
    "worker:protected-api": "node deploy/workers/protected-api-worker.mjs",
    "worker:ws-light-scan": "node deploy/workers/ws-light-scan-worker.mjs",
    "lint": "eslint .",
    "test:market": "tsc -p tsconfig.market-test.json && find .tmp/market-tests/lib -name '*.test.js' -print | sort | xargs node --test && npm run test:workers && npm run test:historical-backtest",
    "test:historical-backtest": "node --test tools/radar-historical-backtest.test.mjs",
    "test:workers": "node --test deploy/workers/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "production:update-coinglass-key": "bash deploy/scripts/update-prod-coinglass-key.sh"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/postcss": "^4.3.1",
    "clsx": "^2.1.1",
    "lucide-react": "latest",
    "next": "latest",
    "pg": "8.16.3",
    "postcss": "8.5.15",
    "react": "latest",
    "react-dom": "latest",
    "redis": "6.0.0",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "8.15.6",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "typescript": "latest"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "browserslist": "> 1%"
}
