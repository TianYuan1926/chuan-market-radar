{
  "name": "chuan-market-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "deployment:env-plan": "tsc -p tsconfig.market-test.json && node .tmp/market-tests/scripts/vercel-env-plan.js",
    "start": "next start",
    "lint": "eslint .",
    "test:market": "tsc -p tsconfig.market-test.json && node --test .tmp/market-tests/lib/api/*.test.js .tmp/market-tests/lib/market/*.test.js .tmp/market-tests/lib/market/providers/*.test.js .tmp/market-tests/lib/analysis/*.test.js .tmp/market-tests/lib/alerts/*.test.js .tmp/market-tests/lib/journal/*.test.js .tmp/market-tests/lib/persistence/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "typescript": "latest"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
